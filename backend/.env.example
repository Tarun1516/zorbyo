# ============================================================
# ZORBYO Backend Configuration
# Copy this file to .env and fill in your credentials
# ============================================================

# ---- Supabase ----
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# Project URL looks like: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ---- Database ----
# LOCAL DEV: Use SQLite (works out of the box, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./zorbyo.db

# PRODUCTION: Use Supabase PostgreSQL (requires: pip install asyncpg)
# Get from: https://supabase.com/dashboard → your project → Settings → Database → Connection string → URI
# Use the pooler connection (port 6543) for serverless environments
# DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# ---- Redis ----
# Used for Socket.IO pub/sub and caching (optional for single-instance dev)
# Install Redis: https://redis.io/download  OR use Docker: docker run -d -p 6379:6379 redis
REDIS_URL=redis://localhost:6379

# ---- Supabase Storage ----
# No extra config needed - uses Supabase client with SUPABASE_SERVICE_ROLE_KEY
# Create buckets in: https://supabase.com/dashboard → Storage
# Required buckets: zorbyo-files, zorbyo-avatars, zorbyo-courses

# ---- JWT Authentication ----
# Supabase handles JWT signing/verification. Keep this for any custom token logic.
SECRET_KEY=your-supabase-jwt-secret-from-settings-api
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- OAuth (configured in Supabase Dashboard) ----
# GitHub: https://supabase.com/dashboard → Authentication → Providers → GitHub
# Google: https://supabase.com/dashboard → Authentication → Providers → Google
# No client_id/secret needed here - they are stored in Supabase

# ---- AI: OpenRouter ----
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# ---- Razorpay (Payments) ----
# Get keys at https://dashboard.razorpay.com/app/keys
# Use Test keys for development, Live keys for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ---- CORS ----
# Include your Supabase project URL here too
CORS_ORIGINS=["http://localhost:19006","http://localhost:3000","http://localhost:8081","http://localhost:8082","https://your-project-ref.supabase.co"]

# ---- Platform Fees (percentage) ----
STUDENT_FEE_PERCENTAGE=3.0
FREELANCER_FEE_PERCENTAGE=5.0

# ---- Account Lockout ----
LOCKOUT_HOURS=72

# ---- Server ----
HOST=0.0.0.0
PORT=4000
